{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profiles and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile photo" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "role": { "type": "string", "enum": ["subscriber", "admin"], "description": "User role" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User document keyed by UID"
    }
  }
}
